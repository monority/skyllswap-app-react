{
  "name": "skyllswap-app-react",
  "private": true,
  "packageManager": "pnpm@8.15.9",
  "scripts": {
    "dev": "pnpm --dir frontend dev",
    "dev:backend": "pnpm --dir backend dev",
    "build": "pnpm --dir frontend build && pnpm --dir backend build",
    "build:frontend": "pnpm --dir frontend build",
    "build:backend": "pnpm --dir backend build",
    "test": "pnpm --dir frontend test",
    "test:backend": "pnpm --dir backend test",
    "test:e2e": "pnpm --dir frontend test:e2e",
    "lint": "pnpm --dir frontend lint",
    "lint:fix": "pnpm --dir frontend lint:fix",
    "format": "pnpm --dir frontend format",
    "format:check": "pnpm --dir frontend format:check"
  },
  "engines": {
    "node": ">=18.18.0",
    "pnpm": ">=8.0.0"
  }
}